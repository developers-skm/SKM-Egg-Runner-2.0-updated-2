rules_version = '2';

// ──────────────────────────────────────────────────────────────
// SKM EGG RUNNER + PROTEIN TRACKER 2.0 — Firestore Security Rules
// ──────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function onlyFields(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    // ── GAME COLLECTIONS ────────────────────────────────────

    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.playerName is string
                    && request.resource.data.playerName.size() >= 2
                    && request.resource.data.playerName.size() <= 30;
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /leaderboard/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.score is int
                    && request.resource.data.score >= 0
                    && request.resource.data.distance >= 0
                    && request.resource.data.playerName is string
                    && request.resource.data.playerName.size() >= 2;
      allow update: if isOwner(uid)
                    && request.resource.data.score >= resource.data.score;
      allow delete: if false;
    }

    match /missions/{uid}/daily/{missionId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    && request.resource.data.progress <= resource.data.target
                    && request.resource.data.progress >= 0
                    && (resource.data.claimed == false || request.resource.data.claimed == true);
      allow delete: if false;
    }

    match /achievements/{uid}/list/{achievementId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    && request.resource.data.progress >= 0
                    && (resource.data.claimed == false || request.resource.data.claimed == true);
      allow delete: if false;
    }

    match /settings/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid)
                   && onlyFields(['uid','musicEnabled','sfxEnabled','vibrationEnabled','reminderEnabled','reminderTimes','updatedAt']);
    }

    match /qrCodes/{code} {
      allow read:   if isAuth();
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playCount'])
                    && request.resource.data.playCount == resource.data.playCount + 1
                    && request.resource.data.playCount <= resource.data.maxPlays;
      allow create: if isAuth();
      allow delete: if false;
    }

    match /gameConfig/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && request.auth.uid == 'YOUR_DEVELOPER_UID';
    }

    // ── PROTEIN TRACKER COLLECTIONS ─────────────────────────

    // Log entries
    match /protein_logs/{uid}/entries/{entryId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.protein is number
                    && request.resource.data.protein >= 0;
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // Daily aggregates
    match /daily_stats/{uid}/days/{dateKey} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // Achievements
    match /tracker_achievements/{uid}/list/{achievementId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // Challenges
    match /tracker_challenges/{uid}/list/{challengeId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // Settings & goals
    match /tracker_settings/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // Reward wallet (coins, XP)
    match /tracker_rewards/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // Protein tracker leaderboard (public-read)
    match /tracker_leaderboard/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // ── RETENTION COLLECTIONS ─────────────────────────────────

    // Daily login reward streak
    match /login_streaks/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid);
    }
    match /login_streaks/{uid}/claims/{claimId} {
      allow read:  if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if false;
      allow delete: if false;
    }

    // Daily missions (3 per day)
    match /daily_missions/{uid}/days/{missionId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // Weekly missions
    match /weekly_missions/{uid}/weeks/{missionId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // Streak shields
    match /streak_shields/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // Game rewards unlocked by protein tracker
    match /game_rewards/{uid}/unlocked/{rewardId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

  }
}
